    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.1",
    "shadcn": "^4.3.0",
